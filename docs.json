              "Agent/Agent_Framework/Framework",
              "Agent/Agent_Framework/Harness",
              "Agent/Agent_Framework/LangChain",
              "Agent/Agent_Framework/LangGraph"
            ]
          },
          {
            "group": "Modern Agent",
            "pages": [
              "Agent/Modern_Agent/openclaw",
              "Agent/Modern_Agent/hermes",
              "Agent/Modern_Agent/claude-code"
            ]
          }
        ]
      },
      {
        "tab": "DeepLearning",
        "groups": [
          {
            "group": "Introduction",
            "pages": [
              "DeepLearning/introduction"
            ]
          },
          {
            "group": "API examples",
            "pages": [
              "DeepLearning/endpoint/get",
