              "DeepLearning/endpoint/delete",
              "DeepLearning/endpoint/webhook"
            ]
          }
        ]
      },
      {
        "tab": "LeetCode",
        "groups": [
          {
            "group": "Roadmap",
            "pages": [
              "LeetCode/mindmap"
            ]
          },
          {
            "group": "数组",
            "pages": [
              "LeetCode/array/array-theory"
