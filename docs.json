{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "VectorPeak",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "favicon": "/images/logo/vectorpeak_no_background.png",
  "redirects": [
    {
      "source": "/Agent/Agent_platforms/openclaw",
      "destination": "/Agent/Modern_Agent/openclaw",
      "permanent": true
    },
    {
      "source": "/Agent/Agent_platforms/hermes",
      "destination": "/Agent/Modern_Agent/hermes",
      "permanent": true
    },
    {
      "source": "/Agent/Agent_platforms/claude-code",
      "destination": "/Agent/Modern_Agent/claude-code",
      "permanent": true
    }
  ],
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart",
              "development"
            ]
          },
          {
            "group": "Customization",
            "pages": [
              "essentials/settings",
              "essentials/navigation"
            ]
          },
          {
            "group": "Writing content",
            "pages": [
              "essentials/markdown",
              "essentials/code",
              "essentials/images",
              "essentials/reusable-snippets"
            ]
          },
          {
            "group": "AI tools",
            "pages": [
              "ai-tools/cursor",
              "ai-tools/claude-code",
              "ai-tools/windsurf"
            ]
          }
        ]
      },
      {
        "tab": "Agent",
        "groups": [
          {
